{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "input-group-demo",
  "registryDependencies": [
    "input-otp"
  ],
  "files": [
    {
      "path": "src/registry/dusk-ui/examples/input-group/input-group-demo.tsx",
      "content": "import {\n  ArrowUpIcon,\n  CheckIcon,\n  InfoIcon,\n  PlusIcon,\n  Search,\n  SearchIcon,\n} from \"lucide-react\";\n\nimport {\n  InputGroup,\n  InputGroupAddon,\n  InputGroupButton,\n  InputGroupInput,\n  InputGroupText,\n  InputGroupTextarea,\n} from \"@/registry/dusk-ui/ui/input-group\";\nimport {\n  Tooltip,\n  TooltipTrigger,\n  TooltipPopup,\n  TooltipProvider,\n} from \"@/registry/dusk-ui/ui/tooltip\";\nimport {\n  Menu,\n  MenuItem,\n  MenuPopup,\n  MenuTrigger,\n} from \"@/registry/dusk-ui/ui/menu\";\nimport { Separator } from \"@/registry/dusk-ui/ui/separator\";\n\nexport function InputGroupDemo() {\n  return (\n    <div className=\"grid w-full max-w-sm gap-6\">\n      <InputGroup>\n        <InputGroupInput\n          type=\"search\"\n          placeholder=\"Search\"\n          aria-label=\"Search\"\n        />\n        <InputGroupAddon>\n          <SearchIcon />\n        </InputGroupAddon>\n      </InputGroup>\n\n      <InputGroup>\n        <InputGroupInput placeholder=\"Search...\" />\n        <InputGroupAddon>\n          <Search />\n        </InputGroupAddon>\n        <InputGroupAddon align=\"inline-end\">12 results</InputGroupAddon>\n      </InputGroup>\n\n      <InputGroup>\n        <InputGroupInput placeholder=\"example.com\" className=\"pl-1!\" />\n        <InputGroupAddon>\n          <InputGroupText>https://</InputGroupText>\n        </InputGroupAddon>\n        <InputGroupAddon align=\"inline-end\">\n          <TooltipProvider>\n            <Tooltip>\n              <TooltipTrigger\n                render={\n                  <InputGroupButton className=\"rounded-full\" size=\"icon-xs\" />\n                }\n              >\n                <InfoIcon />\n              </TooltipTrigger>\n              <TooltipPopup>This is content in a tooltip.</TooltipPopup>\n            </Tooltip>\n          </TooltipProvider>\n        </InputGroupAddon>\n      </InputGroup>\n\n      <InputGroup>\n        <InputGroupTextarea placeholder=\"Ask, Search or Chat...\" />\n        <InputGroupAddon align=\"block-end\">\n          <InputGroupButton\n            variant=\"outline\"\n            className=\"rounded-full\"\n            size=\"icon-xs\"\n          >\n            <PlusIcon />\n          </InputGroupButton>\n          <Menu>\n            <MenuTrigger render={<InputGroupButton variant=\"ghost\" />}>\n              <span>Auto</span>\n            </MenuTrigger>\n            <MenuPopup side=\"top\" align=\"start\" className=\"[--radius:0.95rem]\">\n              <MenuItem>Auto</MenuItem>\n              <MenuItem>Agent</MenuItem>\n              <MenuItem>Manual</MenuItem>\n            </MenuPopup>\n          </Menu>\n          <InputGroupText className=\"ml-auto\">52% used</InputGroupText>\n          <Separator orientation=\"vertical\" className=\"h-4!\" />\n          <InputGroupButton\n            variant=\"default\"\n            className=\"rounded-full\"\n            size=\"icon-xs\"\n            disabled\n          >\n            <ArrowUpIcon />\n            <span className=\"sr-only\">Send</span>\n          </InputGroupButton>\n        </InputGroupAddon>\n      </InputGroup>\n\n      <InputGroup>\n        <InputGroupInput placeholder=\"@shadcn\" />\n        <InputGroupAddon align=\"inline-end\">\n          <div className=\"bg-primary text-primary-foreground flex size-4 items-center justify-center rounded-full\">\n            <CheckIcon className=\"size-3\" />\n          </div>\n        </InputGroupAddon>\n      </InputGroup>\n    </div>\n  );\n}\n",
      "type": "registry:example"
    }
  ],
  "type": "registry:example"
}