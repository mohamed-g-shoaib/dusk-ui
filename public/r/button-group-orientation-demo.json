{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "button-group-orientation-demo",
  "registryDependencies": [
    "button-group"
  ],
  "files": [
    {
      "path": "src/registry/dusk-ui/examples/button-group/button-group-orientation-demo.tsx",
      "content": "import { MinusIcon, PlusIcon, ZoomInIcon, ZoomOutIcon } from \"lucide-react\";\n\nimport { Button } from \"@/registry/dusk-ui/ui/button\";\nimport { ButtonGroup } from \"@/registry/dusk-ui/ui/button-group\";\n\nexport function ButtonGroupOrientationDemo() {\n  return (\n    <div className=\"flex gap-3\">\n      <ButtonGroup\n        orientation=\"vertical\"\n        aria-label=\"Media controls\"\n        className=\"h-fit\"\n      >\n        <Button variant=\"outline\" size=\"icon\">\n          <PlusIcon />\n        </Button>\n        <Button variant=\"outline\" size=\"icon\">\n          <MinusIcon />\n        </Button>\n      </ButtonGroup>\n\n      <ButtonGroup aria-label=\"Zoom controls\" orientation=\"vertical\">\n        <Button aria-label=\"Zoom in\" size=\"icon\" variant=\"outline\">\n          <ZoomInIcon />\n        </Button>\n        <Button aria-label=\"Zoom Out\" size=\"icon\" variant=\"outline\">\n          <ZoomOutIcon />\n        </Button>\n      </ButtonGroup>\n    </div>\n  );\n}\n",
      "type": "registry:example"
    }
  ],
  "type": "registry:example"
}