{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "dialog-nested-demo",
  "registryDependencies": [
    "dialog"
  ],
  "files": [
    {
      "path": "src/registry/dusk-ui/examples/dialog/dialog-nested-demo.tsx",
      "content": "import {\n  Dialog,\n  DialogPopup,\n  DialogDescription,\n  DialogFooter,\n  DialogHeader,\n  DialogTitle,\n  DialogTrigger,\n  DialogClose,\n} from \"@/registry/dusk-ui/ui/dialog\";\n\nimport { Button } from \"@/registry/dusk-ui/ui/button\";\nimport { Input } from \"@/registry/dusk-ui/ui/input\";\nimport { Label } from \"@/registry/dusk-ui/ui/label\";\n\nexport const DialogNestedDemo = () => {\n  return (\n    <Dialog>\n      <DialogTrigger render={<Button />}>View details</DialogTrigger>\n      <DialogPopup showCloseButton={false}>\n        <DialogHeader>\n          <DialogTitle>Manage team member</DialogTitle>\n          <DialogDescription>\n            View and manage a user in your team.\n          </DialogDescription>\n        </DialogHeader>\n        <div className=\"grid gap-4\">\n          <div className=\"grid gap-1\">\n            <p className=\"text-sm text-muted-foreground\">Name</p>\n            <p className=\"text-sm font-medium\">Mohamed</p>\n          </div>\n          <div className=\"grid gap-1\">\n            <p className=\"text-sm text-muted-foreground\">Email</p>\n            <p className=\"text-sm font-medium\">mohamed@kam-ui.com</p>\n          </div>\n        </div>\n        <DialogFooter>\n          <Dialog>\n            <DialogTrigger render={<Button variant=\"outline\" />}>\n              Edit details\n            </DialogTrigger>\n            <DialogPopup showCloseButton={false}>\n              <DialogHeader>\n                <DialogTitle>Edit details</DialogTitle>\n                <DialogDescription>\n                  Make changes to the member&apos;s information.\n                </DialogDescription>\n              </DialogHeader>\n              <div className=\"flex flex-col gap-4\">\n                <div className=\"flex flex-col gap-1\">\n                  <Label htmlFor=\"input-type-name\">Name</Label>\n                  <Input\n                    id=\"input-type-name\"\n                    placeholder=\"Mohamed\"\n                    type=\"text\"\n                  />\n                </div>\n                <div className=\"flex flex-col gap-1\">\n                  <Label htmlFor=\"input-type-email\">Email</Label>\n                  <Input\n                    id=\"input-type-email\"\n                    placeholder=\"mohamed@example.com\"\n                    type=\"text\"\n                  />\n                </div>\n              </div>\n              <DialogFooter>\n                <DialogClose render={<Button variant=\"ghost\" />}>\n                  Cancel\n                </DialogClose>\n                <Button type=\"submit\">Save changes</Button>\n              </DialogFooter>\n            </DialogPopup>\n          </Dialog>\n        </DialogFooter>\n      </DialogPopup>\n    </Dialog>\n  );\n};\n",
      "type": "registry:example"
    }
  ],
  "type": "registry:example"
}