{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "sheet-side-demo",
  "registryDependencies": [
    "sheet"
  ],
  "files": [
    {
      "path": "src/registry/dusk-ui/examples/sheet/sheet-side-demo.tsx",
      "content": "import {\n  Sheet,\n  SheetClose,\n  SheetPopup,\n  SheetDescription,\n  SheetFooter,\n  SheetHeader,\n  SheetTitle,\n  SheetTrigger,\n} from \"@/registry/dusk-ui/ui/sheet\";\nimport { Button } from \"@/registry/dusk-ui/ui/button\";\n\nimport { Label } from \"@/registry/dusk-ui/ui/label\";\nimport { Input } from \"@/registry/dusk-ui/ui/input\";\n\nexport function SheetSideDemo() {\n  const sides = [\"top\", \"right\", \"bottom\", \"left\"] as const;\n\n  return (\n    <div className=\"flex flex-wrap items-center gap-4\">\n      {sides.map((side) => (\n        <Sheet key={side}>\n          <SheetTrigger\n            render={<Button variant=\"outline\" className=\"capitalize\" />}\n          >\n            {side}\n          </SheetTrigger>\n          <SheetPopup side={side}>\n            <SheetHeader className=\"group-data-[side=top]:max-w-lg group-data-[side=top]:mx-auto group-data-[side=bottom]:max-w-lg group-data-[side=bottom]:mx-auto w-full\">\n              <SheetTitle>Edit profile</SheetTitle>\n              <SheetDescription>\n                Make changes to your profile here. Click save when you&apos;re\n                done.\n              </SheetDescription>\n            </SheetHeader>\n            <div className=\"group-data-[side=top]:max-w-lg group-data-[side=top]:mx-auto group-data-[side=bottom]:max-w-lg group-data-[side=bottom]:mx-auto w-full\">\n              <div className=\"grid flex-1 auto-rows-min gap-6 px-4\">\n                <div className=\"grid gap-3\">\n                  <Label htmlFor=\"sheet-demo-name\">Name</Label>\n                  <Input id=\"sheet-demo-name\" defaultValue=\"Pedro Duarte\" />\n                </div>\n                <div className=\"grid gap-3\">\n                  <Label htmlFor=\"sheet-demo-username\">Username</Label>\n                  <Input id=\"sheet-demo-username\" defaultValue=\"@peduarte\" />\n                </div>\n              </div>\n            </div>\n            <SheetFooter className=\"group-data-[side=top]:max-w-lg group-data-[side=top]:mx-auto group-data-[side=bottom]:max-w-lg group-data-[side=bottom]:mx-auto w-full\">\n              <Button type=\"submit\" className=\"w-full\">\n                Save changes\n              </Button>\n              <SheetClose\n                render={<Button variant=\"outline\" className=\"w-full\" />}\n              >\n                Close\n              </SheetClose>\n            </SheetFooter>\n          </SheetPopup>\n        </Sheet>\n      ))}\n    </div>\n  );\n}\n",
      "type": "registry:example"
    }
  ],
  "type": "registry:example"
}