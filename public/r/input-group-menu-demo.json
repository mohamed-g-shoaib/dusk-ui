{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "input-group-menu-demo",
  "registryDependencies": [
    "input-group"
  ],
  "files": [
    {
      "path": "src/registry/dusk-ui/examples/input-group/input-group-menu-demo.tsx",
      "content": "import { ChevronDownIcon, MoreHorizontal } from \"lucide-react\";\n\nimport {\n  InputGroup,\n  InputGroupAddon,\n  InputGroupButton,\n  InputGroupInput,\n  InputGroupText,\n  InputGroupTextarea,\n} from \"@/registry/dusk-ui/ui/input-group\";\n\nimport {\n  Menu,\n  MenuItem,\n  MenuPopup,\n  MenuTrigger,\n} from \"@/registry/dusk-ui/ui/menu\";\n\nexport function InputGroupMenuDemo() {\n  return (\n    <div className=\"grid w-full max-w-sm gap-6\">\n      <InputGroup>\n        <InputGroupInput placeholder=\"Enter file name\" />\n        <InputGroupAddon align=\"inline-end\">\n          <Menu>\n            <MenuTrigger\n              render={\n                <InputGroupButton\n                  variant=\"ghost\"\n                  aria-label=\"More\"\n                  size=\"icon-xs\"\n                />\n              }\n            >\n              <MoreHorizontal />\n            </MenuTrigger>\n            <MenuPopup align=\"end\">\n              <MenuItem>Settings</MenuItem>\n              <MenuItem>Copy path</MenuItem>\n              <MenuItem>Open location</MenuItem>\n            </MenuPopup>\n          </Menu>\n        </InputGroupAddon>\n      </InputGroup>\n\n      <InputGroup className=\"[--radius:1rem]\">\n        <InputGroupInput placeholder=\"Enter search query\" />\n        <InputGroupAddon align=\"inline-end\">\n          <Menu>\n            <MenuTrigger\n              render={\n                <InputGroupButton\n                  variant=\"ghost\"\n                  className=\"pr-1.5! text-xs active:scale-100\"\n                />\n              }\n            >\n              Search In... <ChevronDownIcon className=\"size-3\" />\n            </MenuTrigger>\n            <MenuPopup align=\"end\" className=\"[--radius:0.95rem]\">\n              <MenuItem>Documentation</MenuItem>\n              <MenuItem>Blog Posts</MenuItem>\n              <MenuItem>Changelog</MenuItem>\n            </MenuPopup>\n          </Menu>\n        </InputGroupAddon>\n      </InputGroup>\n    </div>\n  );\n}\n",
      "type": "registry:example"
    }
  ],
  "type": "registry:example"
}