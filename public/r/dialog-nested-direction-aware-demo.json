{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "dialog-nested-direction-aware-demo",
  "registryDependencies": [
    "dialog"
  ],
  "files": [
    {
      "path": "src/registry/dusk-ui/examples/dialog/dialog-nested-direction-aware-demo.tsx",
      "content": "import {\n  Dialog,\n  DialogPopup,\n  DialogDescription,\n  DialogFooter,\n  DialogHeader,\n  DialogTitle,\n  DialogTrigger,\n  DialogClose,\n} from \"@/registry/dusk-ui/ui/dialog\";\n\nimport { Button } from \"@/registry/dusk-ui/ui/button\";\nimport { Input } from \"@/registry/dusk-ui/ui/input\";\nimport { Label } from \"@/registry/dusk-ui/ui/label\";\n\nexport const DialogNestedDirectionAwareDemo = () => {\n  const flips = [\"topFlip\", \"bottomFlip\", \"leftFlip\", \"rightFlip\"] as const;\n  const slides = [\n    \"topSlide\",\n    \"bottomSlide\",\n    \"leftSlide\",\n    \"rightSlide\",\n  ] as const;\n\n  return (\n    <div className=\"grid gap-4\">\n      <div className=\"flex flex-col gap-4\">\n        <div>Flip Animations in nested dialogs</div>\n        <div className=\"flex flex-wrap items-center gap-4\">\n          {flips.map((flip) => (\n            <Dialog key={flip}>\n              <DialogTrigger render={<Button />}>\n                <span className=\"capitalize\">{flip}</span>\n              </DialogTrigger>\n              <DialogPopup showCloseButton={false} animationPreset={flip}>\n                <DialogHeader>\n                  <DialogTitle>Manage team member</DialogTitle>\n                  <DialogDescription>\n                    View and manage a user in your team.\n                  </DialogDescription>\n                </DialogHeader>\n                <div className=\"grid gap-4\">\n                  <div className=\"grid gap-1\">\n                    <p className=\"text-sm text-muted-foreground\">Name</p>\n                    <p className=\"text-sm font-medium\">Mohamed</p>\n                  </div>\n                  <div className=\"grid gap-1\">\n                    <p className=\"text-sm text-muted-foreground\">Email</p>\n                    <p className=\"text-sm font-medium\">mohamed@kam-ui.com</p>\n                  </div>\n                </div>\n                <DialogFooter>\n                  <Dialog>\n                    <DialogTrigger render={<Button variant=\"outline\" />}>\n                      Edit details\n                    </DialogTrigger>\n                    <DialogPopup showCloseButton={false} animationPreset={flip}>\n                      <DialogHeader>\n                        <DialogTitle>Edit details</DialogTitle>\n                        <DialogDescription>\n                          Make changes to the member&apos;s information.\n                        </DialogDescription>\n                      </DialogHeader>\n                      <div className=\"flex flex-col gap-4\">\n                        <div className=\"flex flex-col gap-1\">\n                          <Label htmlFor=\"input-type-name\">Name</Label>\n                          <Input\n                            id=\"input-type-name\"\n                            placeholder=\"Mohamed\"\n                            type=\"text\"\n                          />\n                        </div>\n                        <div className=\"flex flex-col gap-1\">\n                          <Label htmlFor=\"input-type-email\">Email</Label>\n                          <Input\n                            id=\"input-type-email\"\n                            placeholder=\"mohamed@example.com\"\n                            type=\"text\"\n                          />\n                        </div>\n                      </div>\n                      <DialogFooter>\n                        <DialogClose render={<Button variant=\"ghost\" />}>\n                          Cancel\n                        </DialogClose>\n                        <Button type=\"submit\">Save changes</Button>\n                      </DialogFooter>\n                    </DialogPopup>\n                  </Dialog>\n                </DialogFooter>\n              </DialogPopup>\n            </Dialog>\n          ))}\n        </div>\n      </div>\n\n      <div className=\"flex flex-col gap-4\">\n        <div>Slide Animations in nested dialogs</div>\n        <div className=\"flex flex-wrap items-center gap-4\">\n          {slides.map((slide) => (\n            <Dialog key={slide}>\n              <DialogTrigger render={<Button />}>\n                <span className=\"capitalize\">{slide}</span>\n              </DialogTrigger>\n              <DialogPopup showCloseButton={false} animationPreset={slide}>\n                <DialogHeader>\n                  <DialogTitle>Manage team member</DialogTitle>\n                  <DialogDescription>\n                    View and manage a user in your team.\n                  </DialogDescription>\n                </DialogHeader>\n                <div className=\"grid gap-4\">\n                  <div className=\"grid gap-1\">\n                    <p className=\"text-sm text-muted-foreground\">Name</p>\n                    <p className=\"text-sm font-medium\">Mohamed</p>\n                  </div>\n                  <div className=\"grid gap-1\">\n                    <p className=\"text-sm text-muted-foreground\">Email</p>\n                    <p className=\"text-sm font-medium\">mohamed@kam-ui.com</p>\n                  </div>\n                </div>\n                <DialogFooter>\n                  <Dialog>\n                    <DialogTrigger render={<Button variant=\"outline\" />}>\n                      Edit details\n                    </DialogTrigger>\n                    <DialogPopup\n                      showCloseButton={false}\n                      animationPreset={slide}\n                    >\n                      <DialogHeader>\n                        <DialogTitle>Edit details</DialogTitle>\n                        <DialogDescription>\n                          Make changes to the member&apos;s information.\n                        </DialogDescription>\n                      </DialogHeader>\n                      <div className=\"flex flex-col gap-4\">\n                        <div className=\"flex flex-col gap-1\">\n                          <Label htmlFor=\"input-type-name\">Name</Label>\n                          <Input\n                            id=\"input-type-name\"\n                            placeholder=\"Mohamed\"\n                            type=\"text\"\n                          />\n                        </div>\n                        <div className=\"flex flex-col gap-1\">\n                          <Label htmlFor=\"input-type-email\">Email</Label>\n                          <Input\n                            id=\"input-type-email\"\n                            placeholder=\"mohamed@example.com\"\n                            type=\"text\"\n                          />\n                        </div>\n                      </div>\n                      <DialogFooter>\n                        <DialogClose render={<Button variant=\"ghost\" />}>\n                          Cancel\n                        </DialogClose>\n                        <Button type=\"submit\">Save changes</Button>\n                      </DialogFooter>\n                    </DialogPopup>\n                  </Dialog>\n                </DialogFooter>\n              </DialogPopup>\n            </Dialog>\n          ))}\n        </div>\n      </div>\n    </div>\n  );\n};\n",
      "type": "registry:example"
    }
  ],
  "type": "registry:example"
}